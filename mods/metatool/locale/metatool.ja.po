#, lua-format
msgid "metatool:register_tool registered tool \"%s\"."
msgstr "metatool:register_tool ツール \"%s\" を登録しました。"

#: mods/metatool/metatool/api.lua:370
#, lua-format
msgid "metatool:register_tool not registering tool %s because it is already registered."
msgstr "metatool:register_tool ツール %s は既に登録されているため、登録しません。"

#: mods/metatool/metatool/api.lua:378
#, lua-format
