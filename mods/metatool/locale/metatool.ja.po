#, lua-format
msgid "Invalid or nonexistent namespace requested: %s"
msgstr "無効または存在しない名前空間が要求されました: %s"

#: mods/metatool/metatool/api.lua:149
#, lua-format
msgid "Namespace created for: %s"
msgstr "名前空間が作成されました: %s"

#: mods/metatool/metatool/api.lua:185
#, lua-format
msgid "%s cannot inspect %s"
msgstr "%s は %s を調査できません"

