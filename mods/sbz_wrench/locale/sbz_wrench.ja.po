#: mods/sbz_wrench/functions.lua:11
msgid "Cannot pickup node. Owned by @1."
msgstr "ノードを回収できません。所有者: @1"

#: mods/sbz_wrench/functions.lua:12
msgid "Cannot pickup node containing @1."
msgstr "@1 を含むノードは回収できません。"

#: mods/sbz_wrench/functions.lua:13
msgid "Not enough room in inventory to pickup node."
msgstr "インベントリの空き容量が足りないため、ノードを回収できません。"

#: mods/sbz_wrench/functions.lua:14
msgid "Cannot pickup node. Nesting inventories is not allowed."
msgstr "ノードを回収できません。インベントリの入れ子（ネスト）は許可されていません。"

#: mods/sbz_wrench/functions.lua:15
msgid "Cannot pickup node. Node contains too much metadata. (Too much information)"
msgstr "ノードを回収できません。ノードに含まれるメタデータが多すぎます。(情報過多)"

#: mods/sbz_wrench/functions.lua:16
msgid "Cannot pickup node. Node is missing inventory."
msgstr "ノードを回収できません。ノードにインベントリが存在しません。"

#: mods/sbz_wrench/functions.lua:17
msgid "Cannot pickup node. Node doesn't contain metadata?"
msgstr "ノードを回収できません。ノードにメタデータが含まれていないようです。"

#: mods/sbz_wrench/functions.lua:18
msgid "A robotic arm cannot dig that node."
msgstr "ロボットアームでそのノードを掘ることはできません。"

#: mods/sbz_wrench/functions.lua:28
msgid "@1 with items"
msgstr "アイテム入りの @1"

#: mods/sbz_wrench/functions.lua:37
msgid "@1 with text \"@2\""
msgstr "テキスト「@2」が書かれた @1"

#: mods/sbz_wrench/functions.lua:42
msgid "@1 with configuration"
msgstr "設定済みの @1"

#: mods/sbz_wrench/tool.lua:6
msgid "Node Preserver"
msgstr "ノード・プリザーバー"