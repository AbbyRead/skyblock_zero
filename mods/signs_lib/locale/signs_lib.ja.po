#: mods/signs_lib/api.lua:824 mods/signs_lib/api.lua:994
msgid "Locked sign, owned by @1\n"
msgstr "ロックされた看板、所有者: @1\n"

#: mods/signs_lib/api.lua:1301
msgid "Skims through all currently-loaded sign-bearing mapblocks, clears away any entities within each sign's node space, and regenerates their text entities, if any."
msgstr "現在読み込まれている看板を含むすべてのマップブロックを走査し、各看板のノードスペース内にあるエンティティを消去して、テキストエンティティがある場合は再生成します。"

#: mods/signs_lib/api.lua:1320
msgid "There are no signs in the currently-loaded terrain."
msgstr "現在読み込まれている地形内に看板はありません。"

#: mods/signs_lib/api.lua:1326
msgid "Found a total of @1 sign nodes across @2 blocks."
msgstr "@2 ブロックにわたって、合計 @1 個の看板ノードが見つかりました。"

#: mods/signs_lib/api.lua:1327
msgid "Regenerating sign entities ..."
msgstr "看板エンティティを再生成中..."

#: mods/signs_lib/api.lua:1339
msgid "Finished."
msgstr "完了しました。"

#: mods/signs_lib/api.lua:1365
msgid "Write"
msgstr "書き込む"

#: mods/signs_lib/standard_signs.lua:7
msgid "Wooden Wall Sign"
msgstr "木製の壁掛け看板"

#: mods/signs_lib/standard_signs.lua:25
msgid "Steel Wall Sign"
msgstr "スチール製の壁掛け看板"