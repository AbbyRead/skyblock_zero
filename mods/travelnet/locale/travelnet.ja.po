#: mods/travelnet/actions/add_station.lua:8
msgid "The give player is not a player"
msgstr "指定されたプレイヤーはプレイヤーではありません"

#: mods/travelnet/actions/add_station.lua:12
msgid "There is no player with interact privilege named '@1'. Aborting."
msgstr "名前が '@1' でinteract権限を持つプレイヤーが見つかりません。中止します。"

#: mods/travelnet/actions/add_station.lua:27
#: mods/travelnet/actions/update_elevator.lua:23
msgid "at @1 m"
msgstr "高度 @1 m"

#: mods/travelnet/actions/add_station.lua:32
msgid "Please provide a name for this station."
msgstr "このステーションの名前を入力してください。"

#: mods/travelnet/actions/add_station.lua:36
msgid "Please provide the name of the network this station ought to be connected to."
msgstr "このステーションを接続するネットワーク名を入力してください。"

#: mods/travelnet/actions/add_station.lua:44
msgid "You do not have the travelnet_attach priv which is required to attach your box to the network of someone else. Aborting."
msgstr "他人のネットワークにボックスを接続するために必要な travelnet_attach 権限を持っていません。中止します。"

#: mods/travelnet/actions/add_station.lua:59
msgid "A station named '@1' already exists on this network. Please choose a different name!"
msgstr "名前が '@1' のステーションはこのネットワークに既に存在します。別の名前を選んでください。"

#: mods/travelnet/actions/add_station.lua:66
msgid "Network '@1', already contains the maximum number (@2) of allowed stations per network. Please choose a different/new network name."
msgstr "ネットワーク '@1' は、1ネットワークあたりの最大ステーション数 (@2) に既に達しています。別のネットワーク名を選んでください。"

#: mods/travelnet/actions/add_station.lua:85
msgid "Station '@1' has been added to the network '@2', which now consists of @3 station(s)."
msgstr "ステーション '@1' がネットワーク '@2' に追加されました。現在、合計 @3 個のステーションで構成されています。"

#: mods/travelnet/actions/add_station.lua:95
#: mods/travelnet/actions/update_elevator.lua:76
#: mods/travelnet/actions/update_travelnet.lua:233
msgid "Station '@1' on network '@2' (owned by @3) ready for usage."
msgstr "ネットワーク '@2' (@3 所有) のステーション '@1' が利用可能になりました。"

#: mods/travelnet/actions/change_order.lua:20
msgid "This station does not have a network."
msgstr "このステーションにはネットワークが設定されていません。"

#: mods/travelnet/actions/change_order.lua:45
msgid "This station is already the first one on the list."
msgstr "このステーションは既にリストの先頭にあります。"

#: mods/travelnet/actions/change_order.lua:47
msgid "This station is already the last one on the list."
msgstr "このステーションは既にリストの最後にあります。"

#: mods/travelnet/actions/change_order.lua:71
#: mods/travelnet/actions/main.lua:72
#: mods/travelnet/actions/update_elevator.lua:40
#: mods/travelnet/actions/update_travelnet.lua:56
msgid "This @1 belongs to @2. You can't edit it."
msgstr "この @1 は @2 の所有物です。編集することはできません。"

#: mods/travelnet/actions/main.lua:46
msgid "This @1 belongs to @2. You can't remove it."
msgstr "この @1 は @2 の所有物です。削除することはできません。"

#: mods/travelnet/actions/main.lua:52
msgid "You do not have enough room in your inventory."
msgstr "インベントリに十分な空きがありません。"

#: mods/travelnet/actions/main.lua:99
msgid "Please click on the target you want to travel to."
msgstr "移動先のターゲットをクリックしてください。"

#: mods/travelnet/actions/repair_station.lua:15
msgid "Update failed! Resetting this box on the travelnet."
msgstr "更新に失敗しました！トラベルネット上のこのボックスをリセットします。"

#: mods/travelnet/actions/repair_station.lua:39
msgid "Station '@1' has been reattached to the network '@2'."
msgstr "ステーション '@1' がネットワーク '@2' に再接続されました。"

#: mods/travelnet/actions/transport_player.lua:20
msgid "Station '@1' does not exist (anymore?) on this network."
msgstr "ステーション '@1' はこのネットワークに（もう）存在しません。"

#: mods/travelnet/actions/transport_player.lua:33
msgid "You are not allowed to travel to this station."
msgstr "このステーションへの移動は許可されていません。"

#: mods/travelnet/actions/update_elevator.lua:14
#: mods/travelnet/actions/update_travelnet.lua:20
#: mods/travelnet/on_receive_fields.lua:28
msgid "Unknown node."
msgstr "不明なノードです。"

#: mods/travelnet/actions/update_elevator.lua:18
#: mods/travelnet/actions/update_travelnet.lua:9
msgid "Invalid data or node."
msgstr "データまたはノードが無効です。"

#: mods/travelnet/actions/update_elevator.lua:55
#: mods/travelnet/actions/update_travelnet.lua:149
#: mods/travelnet/actions/update_travelnet.lua:203
msgid "Station \"@1\" already exists on network \"@2\"."
msgstr "ステーション \"@1\" はネットワーク \"@2\" に既に存在します。"

#: mods/travelnet/actions/update_elevator.lua:62
#: mods/travelnet/actions/update_travelnet.lua:210
msgid "Station does exist."
msgstr "ステーションは存在します。"

#: mods/travelnet/actions/update_elevator.lua:72
#: mods/travelnet/actions/update_travelnet.lua:220
msgid "Station \"@1\" has been renamed to \"@2\" on network \"@3\"."
msgstr "ネットワーク \"@3\" のステーション \"@1\" は \"@2\" に名前が変更されました。"

#: mods/travelnet/actions/update_travelnet.lua:33
msgid "Please provide a station name."
msgstr "ステーション名を入力してください。"

#: mods/travelnet/actions/update_travelnet.lua:37
msgid "Please provide a network name."
msgstr "ネットワーク名を入力してください。"

#: mods/travelnet/actions/update_travelnet.lua:41
msgid "Please provide an owner."
msgstr "所有者を指定してください。"

#: mods/travelnet/actions/update_travelnet.lua:67
msgid "You don't have permission to change the owner of this travelnet"
msgstr "このトラベルネットの所有者を変更する権限がありません"

#: mods/travelnet/actions/update_travelnet.lua:85
msgid "Station \"@1\" already exists on network \"@2\" of player \"@3\"."
msgstr "プレイヤー \"@3\" のネットワーク \"@2\" には、ステーション \"@1\" が既に存在します。"

#: mods/travelnet/actions/update_travelnet.lua:92
#: mods/travelnet/actions/update_travelnet.lua:156
msgid "Network \"@1\", already contains the maximum number (@2) of allowed stations per network. Please choose a different network name."
msgstr "ネットワーク \"@1\" は、1ネットワークあたりの最大ステーション数 (@2) に既に達しています。別のネットワーク名を選んでください。"

#: mods/travelnet/actions/update_travelnet.lua:103
#: mods/travelnet/actions/update_travelnet.lua:166
msgid "Station does not have network."
msgstr "ステーションにネットワークがありません。"

#: mods/travelnet/actions/update_travelnet.lua:118
msgid "Station \"@1\" has been renamed to \"@2\", moved from network \"@3\" to network \"@4\" and from owner \"@5\" to owner \"@6\"."
msgstr "ステーション \"@1\" は \"@2\" に名前変更され、ネットワーク \"@3\" から \"@4\" へ、所有者 \"@5\" から \"@6\" へ移動されました。"

#: mods/travelnet/actions/update_travelnet.lua:178
msgid "Station \"@1\" has been renamed to \"@2\" and moved from network \"@3\" to network \"@4\"."
msgstr "ステーション \"@1\" は \"@2\" に名前変更され、ネットワーク \"@3\" から \"@4\" へ移動されました。"

#: mods/travelnet/add_target.lua:19 mods/travelnet/formspecs.lua:33
